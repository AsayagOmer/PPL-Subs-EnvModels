#lang racket

(provide eval_ user-eval global-env)

(require "adt.rkt"
         "parser.rkt")

;; ==========================================
;; Environment Management
;; ==========================================
(define global-env '())

(define (extend-env! var val)
  (set! global-env
        (cons (cons var val) global-env)))

;; Update an existing variable in the environment (used for set!)
(define (update-env var val env)
  (cond
    [(null? env) (error "Unbound variable:" var)]
    [(eq? (car (car env)) var) (cons (cons var val) (cdr env))]
    [else (cons (car env) (update-env var val (cdr env)))]))

;; --- Logical Primitive Functions (Scheme Standard) ---
(define (prim-and . args)
  (let loop ((lst args))
    (cond [(null? lst) #t]
          [(eq? (car lst) #f) #f]
          [(null? (cdr lst)) (car lst)]
          [else (loop (cdr lst))])))

(define (prim-or . args)
  (let loop ((lst args))
    (cond [(null? lst) #f]
          [(not (eq? (car lst) #f)) (car lst)]
          [else (loop (cdr lst))])))

(define (prim-xor a b)
  (let ((bool-a (not (eq? a #f)))
        (bool-b (not (eq? b #f))))
    (cond [(and bool-a (not bool-b)) a]
          [(and (not bool-a) bool-b) b]
          [else #f])))

(define (init-global-env)
  (begin
    (extend-env! '+ +)
    (extend-env! '- -)
    (extend-env! '* *)
    (extend-env! '/ /)
    (extend-env! '> >)
    (extend-env! '< <)
    (extend-env! '= =)
    ;; Arithmetic shortcuts
    (extend-env! 'add1 add1)
    (extend-env! 'sub1 sub1)
    ;; Logical Operators
    (extend-env! 'not not)
    (extend-env! 'and prim-and)
    (extend-env! 'or prim-or)
    (extend-env! 'xor prim-xor)
    ;; List Processing Primitives
    (extend-env! 'cons cons)
    (extend-env! 'car car)
    (extend-env! 'cdr cdr)
    (extend-env! 'null? null?)
    (extend-env! 'list list)
    (extend-env! 'equal? equal?)
    (extend-env! 'display display)
    (extend-env! 'newline newline)))

(init-global-env)

;; Look up variables in the environment
(define (lookup-helper var env)
  (cond
    [(null? env) 'unbound]
    [(equal? (car (car env)) var) (cdr (car env))]
    [else (lookup-helper var (cdr env))]))

(define (lookup var)
  (lookup-helper var global-env))

(define (is-defined? var)
  (not (eq? (lookup var) 'unbound)))

;; Primitive Procedure Predicate
(define (primitive-procedure? op)
  (procedure? op))

;; ==========================================
;; Core Syntax Recognizers (for begin and quote)
;; ==========================================
(define (begin? expr)
  (and (list? expr) (eq? (car expr) 'begin)))

(define (begin-actions expr)
  (cdr expr))

(define (quote? expr)
  (and (list? expr) (eq? (car expr) 'quote)))

(define (quote-text expr)
  (cadr expr))

;; ==========================================
;; Core Evaluator
;; ==========================================

;; Evaluate expressions
(define (eval_ expr)
  (cond
    [(primitive? expr) expr]
    [(value? expr) expr]
    [(symbol? expr) (eval-var expr)]
    [(quote? expr) (quote-text expr)]
    [(set!? expr) (eval-set! expr)]          ;; <--- set! evaluation is routed here
    [(define? expr) (eval-define expr)]
    [(if? expr) (eval-if expr)]
    [(lambda? expr) (eval-lambda expr)]
    [(begin? expr) (eval-begin (begin-actions expr))]
    [(application? expr)
     (eval-application (eval_ (application-operator expr))
                       (map eval_ (application-operands expr)))]
    [else (error "Unknown expression:" expr)]))

;; Variable evaluation
(define (eval-var expr)
  (let ((val (lookup expr)))
    (if (eq? val 'unbound)
        (error "Unbound variable:" expr)
        val)))

;; `define` evaluation
(define (eval-define expr)
  (let ((var (define-variable expr))
        (val (eval_ (define-value expr))))
    (if (is-defined? var)
        (error "Variable already defined:" var)
        (begin
          (extend-env! var val)
          var))))

;; `set!` evaluation
(define (eval-set! expr)
  (let ((var (set-variable expr))
        (val (eval_ (set-value expr))))
    ;; Check if the variable is still a symbol.
    ;; If the substitution model replaced it with a value, this will fail!
    (if (symbol? var)
        (if (is-defined? var)
            (begin
              (set! global-env (update-env var val global-env))
              (void)) ;; set! returns void (no output) in Scheme
            (error "set!: Unbound variable:" var))
        (error "set!: Cannot assign to non-symbol (Substitution model replaced the local variable with a value!):" var))))

;; `if` evaluation
(define (eval-if expr)
  (let ((test (eval_ (if-test expr)))
        (then-branch (if-then expr))
        (else-branch (if-else expr)))
    (if (true? test)
        (eval_ then-branch)
        (eval_ else-branch))))

(define (true? v)
  (not (eq? v #f)))

;; `lambda` evaluation
(define (eval-lambda expr)
  (make-closure (lambda-params expr)
                (lambda-body expr)))

;; `begin` evaluation
(define (eval-begin actions)
  (cond
    [(null? actions) (void)]
    [(null? (cdr actions)) (eval_ (car actions))]
    [else
     (begin
       (eval_ (car actions))
       (eval-begin (cdr actions)))]))

;; Application evaluation
(define (eval-application op args)
  (cond
    [(primitive-procedure? op) (apply op args)]
    [(closure? op)
     (let ((params (closure-params op))
           (body (closure-body op)))
       (eval_ (substitute-all body params args)))]
    [else (error "Unknown operator or unbound variable:" op)]))

;; ==========================================
;; Substitution Model Logic
;; ==========================================

;; Substitution
(define (substitute expr var val)
  (cond
    [(symbol? expr) (if (eq? expr var) val expr)]
    [(set!? expr) 
     ;; This is where the substitution model breaks local set!
     ;; If the variable being assigned matches the parameter, it is replaced by its value.
     (make-set! (if (eq? (set-variable expr) var)
                    val   
                    (set-variable expr))
                (substitute (set-value expr) var val))]
    [(lambda? expr)
     (let ((params (lambda-params expr))
           (body (lambda-body expr)))
       (if (member var params)
           expr
           (make-lambda params (substitute body var val))))]
    [(list? expr)
      (map (lambda (arg) (substitute arg var val))
           expr)]
    [else expr]))

(define (substitute-all expr vars vals)
  (if (null? vars)
      expr
      (substitute-all
       (substitute expr (car vars) (car vals))
       (cdr vars) (cdr vals))))

;; User-level evaluation
(define (user-eval input)
  (eval_ (parse-expression input)))